@inject BugContextCollector Collector
@inject MultiDestinationDispatcher Dispatcher
@inject BugSnapOptions Options

@if (Visible)
{
    <div class="bs-backdrop" @onclick="HandleBackdropClick">
        <div class="bs-modal" @onclick:stopPropagation>
            <div class="bs-modal-header">
                <span class="bs-modal-title">Reportar problema</span>
                <button class="bs-close-btn" @onclick="HandleCancel" aria-label="Fechar">&times;</button>
            </div>

            <div class="bs-modal-body">
                @if (_rateLimited)
                {
                    <div class="bs-alert bs-alert-warning">
                        Aguarde @_rateLimitSecondsRemaining segundo(s) antes de enviar outro relatório.
                    </div>
                }

                @if (_submitSuccess)
                {
                    <div class="bs-alert bs-alert-success">
                        Problema reportado! Obrigado.
                    </div>
                }

                @if (_submitError is not null)
                {
                    <div class="bs-alert bs-alert-error">
                        Erro ao enviar. Tente novamente.
                    </div>
                }

                <div class="bs-field">
                    <label class="bs-label" for="bs-description">Descreva o problema</label>
                    <textarea id="bs-description" class="bs-textarea" rows="5"
                              placeholder="O que aconteceu?"
                              @bind="_description" @bind:event="oninput" maxlength="2000"></textarea>
                </div>

                <div class="bs-screenshot-row">
                    <InputFile id="bs-screenshot-input" class="bs-file-input-hidden" accept="image/*" OnChange="HandleFileSelected" />
                    <label for="bs-screenshot-input" class="bs-screenshot-btn" title="Anexar screenshot">
                        📷
                        @if (_screenshotFileName is not null)
                        {
                            <span class="bs-screenshot-name">@_screenshotFileName</span>
                        }
                        else
                        {
                            <span class="bs-screenshot-label">Screenshot (opcional)</span>
                        }
                    </label>
                </div>
            </div>

            <div class="bs-modal-footer">
                <button class="bs-btn bs-btn-secondary" type="button" @onclick="HandleCancel"
                        disabled="@_submitting">
                    Cancelar
                </button>
                <button class="bs-btn bs-btn-primary" type="button" @onclick="HandleSubmit"
                        disabled="@(_submitting || _rateLimited || string.IsNullOrWhiteSpace(_description))">
                    @if (_submitting)
                    {
                        <span>Enviando...</span>
                    }
                    else
                    {
                        <span>Enviar</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback<BugReport> OnReportSubmitted { get; set; }

    private string _description = "";
    private byte[]? _screenshotBytes;
    private string? _screenshotFileName;

    private BugContextSnapshot? _context;
    private bool _submitting;
    private bool _submitSuccess;
    private string? _submitError;
    private bool _rateLimited;
    private int _rateLimitSecondsRemaining;

    private static DateTime _lastSubmitTime = DateTime.MinValue;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && _context is null)
        {
            await LoadContextAsync();
        }
    }

    private async Task LoadContextAsync()
    {
        try
        {
            _context = await Collector.CollectAsync();
        }
        catch
        {
            // Context collection failing should not block the form
            _context = new BugContextSnapshot();
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        const long maxSize = 2 * 1024 * 1024; // 2MB
        if (file.Size > maxSize) return;

        using var stream = file.OpenReadStream(maxSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _screenshotBytes = ms.ToArray();
        _screenshotFileName = file.Name;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_description))
            return;

        var secondsSinceLast = (DateTime.UtcNow - _lastSubmitTime).TotalSeconds;
        if (secondsSinceLast < Options.RateLimitSeconds)
        {
            _rateLimited = true;
            _rateLimitSecondsRemaining = (int)Math.Ceiling(Options.RateLimitSeconds - secondsSinceLast);
            return;
        }

        _submitting = true;
        _submitSuccess = false;
        _submitError = null;
        _rateLimited = false;

        try
        {
            if (_context is null)
                _context = await Collector.CollectAsync();

            var title = _description.Trim().Length > 50
                ? _description.Trim()[..50]
                : _description.Trim();
            if (string.IsNullOrEmpty(title)) title = "Bug report";

            var severity = DetectSeverity(_context);
            var category = _context.SuggestedCategory ?? BugSnapCategory.Other;

            var report = new BugReport
            {
                Title = title,
                Description = _description.Trim(),
                Severity = severity,
                Category = category,
                Screenshot = _screenshotBytes,
                ScreenshotFileName = _screenshotFileName,
                Fingerprint = FingerprintGenerator.Generate(_context),
                Context = _context
            };

            var results = await Dispatcher.DispatchAsync(report);

            _lastSubmitTime = DateTime.UtcNow;

            var anySuccess = results.Any(r => r.Success);
            if (anySuccess)
            {
                _submitSuccess = true;
                await OnReportSubmitted.InvokeAsync(report);
                ResetForm();
            }
            else
            {
                var errors = results.Where(r => !r.Success).Select(r => r.Error).Where(e => e is not null);
                _submitError = string.Join("; ", errors);
                if (string.IsNullOrEmpty(_submitError))
                    _submitError = "Falha ao enviar para todos os destinos.";
            }
        }
        catch (Exception ex)
        {
            _submitError = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private static BugSnapSeverity DetectSeverity(BugContextSnapshot context)
    {
        var requests = context.RecentRequests;
        var jsErrors = context.RecentJsErrors;

        // 5xx errors or JS errors → High
        if (requests.Any(r => r.StatusCode >= 500) || jsErrors.Count > 0)
            return BugSnapSeverity.High;

        // 4xx errors or SignalR issues → Medium
        var signalRIssue = context.SignalRState is not null
            && !string.Equals(context.SignalRState, "Connected", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(context.SignalRState, "Connecting", StringComparison.OrdinalIgnoreCase);
        if (requests.Any(r => r.StatusCode >= 400 && r.StatusCode < 500) || signalRIssue)
            return BugSnapSeverity.Medium;

        return BugSnapSeverity.Low;
    }

    private void HandleCancel()
    {
        ResetForm();
        VisibleChanged.InvokeAsync(false);
    }

    private void HandleBackdropClick()
    {
        if (!_submitting)
            HandleCancel();
    }

    private void ResetForm()
    {
        _description = "";
        _screenshotBytes = null;
        _screenshotFileName = null;
        _context = null;
        _submitSuccess = false;
        _submitError = null;
        _rateLimited = false;
    }
}
